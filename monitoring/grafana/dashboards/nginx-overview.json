{
  "title": "Nginx Overview",
  "uid": "nginx-overview",
  "tags": ["nginx", "dzcash"],
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "nginx_connections_active",
        "legendFormat": "active"
      }]
    },
    {
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "rate(nginx_http_requests_total[1m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "rate(nginx_http_requests_total{status=~'2..'}[1m])", "legendFormat": "2xx"},
        {"expr": "rate(nginx_http_requests_total{status=~'4..'}[1m])", "legendFormat": "4xx"},
        {"expr": "rate(nginx_http_requests_total{status=~'5..'}[1m])", "legendFormat": "5xx"}
      ]
    },
    {
      "title": "Upstream Response Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "nginx_upstream_response_time_seconds",
        "legendFormat": "response time"
      }]
    }
  ]
}
