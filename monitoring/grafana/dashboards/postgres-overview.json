{
  "title": "PostgreSQL Overview",
  "uid": "postgres-overview",
  "tags": ["postgres", "dzcash"],
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "pg_stat_database_numbackends{datname='dzcash'}",
        "legendFormat": "connections"
      }]
    },
    {
      "title": "Transactions per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "rate(pg_stat_database_xact_commit{datname='dzcash'}[1m])",
        "legendFormat": "commits"
      }]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "expr": "(pg_stat_database_blks_hit{datname='dzcash'} / (pg_stat_database_blks_hit{datname='dzcash'} + pg_stat_database_blks_read{datname='dzcash'})) * 100",
        "legendFormat": "hit ratio"
      }]
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "pg_database_size_bytes{datname='dzcash'} / 1024 / 1024",
        "legendFormat": "size (MB)"
      }]
    }
  ]
}
