# === Required: Database ===
POSTGRES_PASSWORD="change-me"

# === Required: Redis ===
REDIS_PASSWORD="change-me"

# === Required: JWT ===
JWT_SECRET="generate-a-random-256-bit-key"
JWT_REFRESH_SECRET="generate-another-random-256-bit-key"

# === Required: Postback Provider Secrets ===
CPX_SECRET="change-me"
OFFERTORO_SECRET="change-me"

# === Required: VPN Detection ===
# Get a free API key from https://www.ipqualityscore.com/create-account
IPQS_API_KEY="your-ipqualityscore-api-key"

# === Optional: Grafana ===
GRAFANA_USER="admin"
GRAFANA_PASSWORD="change-me"

# === Optional: SMTP ===
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@dzcash.com"
SMTP_FROM_NAME="DZCASH"

# === Optional: Frontend URL ===
FRONTEND_URL="http://localhost:3000"

# === Optional: Postback IP whitelist (comma-separated) ===
# Leave empty to allow all IPs (dev), set specific IPs for production
POSTBACK_ALLOWED_IPS=""
