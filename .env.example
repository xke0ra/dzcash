# ============ Database ============
DATABASE_URL=postgresql://dzuser:dzpass@localhost:5432/dzcash?schema=public

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT ============
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-strong-random-secret-in-production

# ============ Application ============
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_VERSION=1.0.0
LOG_LEVEL=debug

# ============ SMTP (Email) ============
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dzcash.com
SMTP_FROM_NAME=DZCASH
SMTP_SECURE=false

# ============ Offer Providers ============
CPX_SECRET=cpx_secret_key_123456
OFFERTORO_SECRET=offertoro_secret_key_abcdef
GENERIC_PROVIDER_TOKEN=generic_token_xyz_987

# ============ Fraud Detection ============
VPN_API_MOCK=true

# ============ Grafana ============
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
